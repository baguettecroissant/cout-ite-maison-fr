---
// DpeBar.astro — Animated DPE ratings indicator (G -> B)
interface Props {
  beforeClass?: 'A' | 'B' | 'C' | 'D' | 'E' | 'F' | 'G';
  afterClass?: 'A' | 'B' | 'C' | 'D' | 'E' | 'F' | 'G';
  savingsAmount?: string;
}

const { 
  beforeClass = 'G', 
  afterClass = 'B',
  savingsAmount = '1 200€'
} = Astro.props;

const dpeScale = [
  { letter: 'A', label: '≤ 70', color: 'bg-dpe-a', textColor: 'text-white' },
  { letter: 'B', label: '71 - 110', color: 'bg-dpe-b', textColor: 'text-white' },
  { letter: 'C', label: '111 - 180', color: 'bg-dpe-c', textColor: 'text-dark' },
  { letter: 'D', label: '181 - 250', color: 'bg-dpe-d', textColor: 'text-dark' },
  { letter: 'E', label: '251 - 330', color: 'bg-dpe-e', textColor: 'text-dark' },
  { letter: 'F', label: '331 - 420', color: 'bg-dpe-f', textColor: 'text-white' },
  { letter: 'G', label: '> 420', color: 'bg-dpe-g', textColor: 'text-white' },
];

const getDpePositionPercent = (letter: string) => {
  const index = dpeScale.findIndex(d => d.letter === letter);
  if (index === -1) return 0;
  return (index / (dpeScale.length - 1)) * 100;
};

const startPos = getDpePositionPercent(beforeClass);
const endPos = getDpePositionPercent(afterClass);
---

<div class="bg-white rounded-2xl border border-gray-200/80 p-6 shadow-md max-w-2xl mx-auto my-8 animate-fade-up">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-b border-gray-100 pb-4 mb-6">
    <div>
      <h3 class="font-bitter font-bold text-lg text-gray-900">🚀 Gain Énergétique (DPE) estimé après ITE</h3>
      <p class="text-sm text-gray-500">Isolation par l'extérieur R ≥ 3.7 m².K/W</p>
    </div>
    <div class="bg-secondary-light border border-secondary/20 rounded-xl px-4 py-2 text-center">
      <span class="text-xs text-secondary font-bold uppercase tracking-wider block">Économies Estimées</span>
      <span class="font-space font-extrabold text-lg text-secondary block animate-pulse">~ {savingsAmount} / an</span>
    </div>
  </div>

  <!-- Horizontal DPE Bar Scale -->
  <div class="relative pt-8 pb-10 px-4">
    <!-- DPE Track -->
    <div class="h-6 w-full rounded-full flex overflow-hidden shadow-inner border border-gray-200/50">
      {dpeScale.map((d) => (
        <div class={`h-full flex-1 ${d.color} flex items-center justify-center font-space font-bold text-xs ${d.textColor}`}>
          {d.letter}
        </div>
      ))}
    </div>

    <!-- Animated Pointer / Indicator -->
    <!-- We animate the left positioning from beforeClass (G = 100%) to afterClass (B = 16.6%) -->
    <div 
      class="absolute top-[20px] -translate-x-1/2 flex flex-col items-center z-10 dpe-indicator pointer-events-none"
      style={`--dpe-start: ${startPos}%; --dpe-target: ${endPos}%;`}
    >
      <!-- Cursor Label -->
      <div class="bg-dark text-white text-[10px] font-bold font-space uppercase px-2 py-0.5 rounded shadow-lg flex items-center gap-1 border border-white/10">
        🏠 Votre Maison
      </div>
      <!-- Triangle pointer -->
      <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-b-[8px] border-b-dark mt-0.5"></div>
      
      <!-- Inner line indicator crossing track -->
      <div class="w-1 h-7 bg-dark/40 mt-0.5"></div>
    </div>
    
    <!-- Scale Limits Labels -->
    <div class="absolute bottom-3 left-4 text-[10px] font-bold font-space text-dpe-a flex items-center gap-1">
      🟢 Très Économe (A)
    </div>
    <div class="absolute bottom-3 right-4 text-[10px] font-bold font-space text-dpe-g flex items-center gap-1">
      🔴 Passoire (G)
    </div>
  </div>

  <!-- Comparison Summary Cards -->
  <div class="grid grid-cols-2 gap-4 mt-2">
    <!-- Before Block -->
    <div class="bg-red-50/60 border border-red-100 rounded-xl p-3.5 text-center flex flex-col items-center justify-center">
      <span class="text-[10px] text-red-600 font-bold uppercase tracking-wider block">Avant Travaux</span>
      <div class="w-10 h-10 rounded-lg bg-dpe-g flex items-center justify-center font-space font-extrabold text-white text-lg shadow-sm border border-red-500/20 my-1.5">
        {beforeClass}
      </div>
      <span class="text-[11px] text-red-800 font-medium">Logement très énergivore</span>
    </div>

    <!-- After Block -->
    <div class="bg-green-50/60 border border-green-100 rounded-xl p-3.5 text-center flex flex-col items-center justify-center">
      <span class="text-[10px] text-green-700 font-bold uppercase tracking-wider block">Après ITE</span>
      <div class="w-10 h-10 rounded-lg bg-dpe-b flex items-center justify-center font-space font-extrabold text-white text-lg shadow-sm border-green-500/20 my-1.5 animate-bounce">
        {afterClass}
      </div>
      <span class="text-[11px] text-green-800 font-medium">Bâtiment Basse Consommation</span>
    </div>
  </div>
</div>

<style>
/* CSS Slide-in Pointer Animation */
@keyframes slide-pointer {
  0% {
    left: var(--dpe-start, 100%);
  }
  100% {
    left: var(--dpe-target, 16.6%);
  }
}

.dpe-indicator {
  animation: slide-pointer 2.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  animation-delay: 0.5s; /* Delay for nice entrance */
  left: var(--dpe-start, 100%);
}
</style>
