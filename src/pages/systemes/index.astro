---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import { brands } from '../../data/brands';
import { blogArticles } from '../../data/blog-articles';
import { techniques } from '../../data/techniques';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Systèmes & Marques ITE — ${siteConfig.name}`,
    "description": "Retrouvez les fiches des plus grands fabricants de systèmes ITE certifiés par le CSTB : STO, Weber, Parexlanko, Baumit, Knauf, Myral.",
    "url": `https://www.${siteConfig.domain}/systemes`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://www.${siteConfig.domain}` },
      { "@type": "ListItem", "position": 2, "name": "Systèmes ITE" },
    ]
  }
];
---

<BaseLayout
  title={`Systèmes & Fabricants ITE RGE 2026 : Comparatif & Tarifs | ${siteConfig.name}`}
  description="Découvrez notre comparatif complet des 6 plus grandes marques de systèmes d'isolation par l'extérieur (ITE) en France : STO, Weber, Parexlanko, Baumit, Knauf, Myral."
  canonical="/systemes"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4">
      <span class="inline-flex bg-white/10 px-3.5 py-1.5 rounded-full text-xs font-semibold tracking-wider font-space uppercase">
        🏭 SYSTÈMES HOMOLOGUÉS CSTB / ATE
      </span>
      <h1 class="text-3xl md:text-5xl font-bitter font-extrabold text-white">
        Marques & Fabricants d'Isolation Extérieure (ITE)
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto font-light">
        L'ITE est un système complet certifié. Découvrez les gammes phares, les tarifs moyens et les avis des applicateurs sur les plus grands fabricants mondiaux.
      </p>
    </div>
  </section>

  <!-- Brands list grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {brands.map((b) => (
        <div class="bg-white border border-gray-200 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between">
          <div class="space-y-4">
            <div class="flex items-center justify-between border-b border-gray-100 pb-3">
              <h2 class="font-bitter font-bold text-xl text-gray-900">{b.name}</h2>
              <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-[10px] font-space font-semibold uppercase">{b.origin}</span>
            </div>
            
            <div class="space-y-1">
              <p class="text-xs text-gray-400 font-space uppercase tracking-wider">Positionnement</p>
              <p class="text-xs font-bold text-slate-800 font-space">{b.segment}</p>
            </div>

            <div class="space-y-1">
              <p class="text-xs text-gray-400 font-space uppercase tracking-wider">Système Phare</p>
              <p class="text-xs font-bold text-teal-700 font-space">{b.phareSystem}</p>
            </div>

            <p class="text-xs text-gray-600 leading-relaxed font-light line-clamp-4">
              {b.description}
            </p>
          </div>

          <div class="pt-6 mt-6 border-t border-gray-50 flex items-center justify-between">
            <div class="flex items-center gap-1">
              <span class="text-amber-500 font-bold text-sm">⭐ {b.starRating}</span>
              <span class="text-[10px] text-gray-400 font-space">({b.voteCount} avis)</span>
            </div>
            <a href={`/systemes/${b.slug}`} class="text-secondary hover:text-secondary-dark text-xs font-bold font-space">
              Consulter la fiche →
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Cross-linking vers autres silos -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-3">
        <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">📚 Guides Experts ITE</h3>
        <ul class="space-y-2">
          {blogArticles.slice(0, 4).map((g) => (
            <li>
              <a href={`/guides/${g.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5 leading-relaxed">
                {g.emoji} {g.title}
              </a>
            </li>
          ))}
        </ul>
        <a href="/guides" class="text-[11px] text-secondary font-bold font-space hover:underline block pt-1">Tous les guides →</a>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-3">
        <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">⚙️ Techniques de Pose ITE</h3>
        <ul class="space-y-2">
          {techniques.map((t) => (
            <li>
              <a href={`/techniques/${t.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5">
                {t.emoji} {t.shortName} — {t.priceRange}
              </a>
            </li>
          ))}
        </ul>
        <a href="/techniques" class="text-[11px] text-secondary font-bold font-space hover:underline block pt-1">Comparatif complet →</a>
      </div>
    </div>
  </section>
</BaseLayout>
