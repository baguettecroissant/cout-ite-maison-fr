---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteWidget from '../../components/QuoteWidget.astro';
import { siteConfig } from '../../../site.config';
import { brands, type Brand } from '../../data/brands';

export function getStaticPaths() {
  return brands.map(brand => ({
    params: { slug: brand.slug },
    props: { brand },
  }));
}

const { brand } = Astro.props as { brand: Brand };

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": `Système ITE ${brand.name}`,
    "image": `https://www.${siteConfig.domain}/images/ite-chantier.webp`,
    "description": brand.description,
    "brand": {
      "@type": "Brand",
      "name": brand.name
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": brand.starRating.toString(),
      "reviewCount": brand.voteCount.toString(),
      "bestRating": "5",
      "worstRating": "1"
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "EUR",
      "lowPrice": "100",
      "highPrice": "230",
      "priceRange": brand.priceRange
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://www.${siteConfig.domain}` },
      { "@type": "ListItem", "position": 2, "name": "Systèmes ITE", "item": `https://www.${siteConfig.domain}/systemes` },
      { "@type": "ListItem", "position": 3, "name": brand.name },
    ]
  }
];
---

<BaseLayout
  title={`Système ITE ${brand.name} : Prix, Gammes & Avis Installateurs 2026`}
  description={`Quel est le prix au m² du système ITE ${brand.name} ? Retrouvez la présentation de StoTherm/Webertherm, les avis des façadiers, les points forts et fiches CSTB.`}
  canonical={`/systemes/${brand.slug}`}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-4">
      <nav class="text-xs text-gray-400 font-space flex items-center gap-1.5">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        <span>›</span>
        <a href="/systemes" class="hover:text-white transition-colors">Systèmes ITE</a>
        <span>›</span>
        <span class="text-gray-300">{brand.name}</span>
      </nav>

      <div class="flex items-center gap-2">
        <span class="bg-teal-500/20 text-teal-300 border border-teal-500/30 px-3.5 py-1.5 rounded-full text-xs font-bold font-space uppercase tracking-wider">
          Système certifié CSTB
        </span>
        <span class="bg-white/10 text-white px-3.5 py-1.5 rounded-full text-xs font-bold font-space uppercase">
          {brand.origin}
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-bitter font-extrabold leading-tight text-white max-w-3xl">
        Système ITE {brand.name} : Prix, Gamme & Avis Installateurs 2026
      </h1>

      <div class="flex items-center gap-4 text-xs text-gray-300 font-space pt-2">
        <span>⭐ Note globale : <strong class="text-amber-400">{brand.starRating}/5</strong> ({brand.voteCount} votes)</span>
        <span>📊 Positionnement : <strong>{brand.segment}</strong></span>
      </div>
    </div>
  </section>

  <!-- Content Space -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-12 gap-10">
      
      <!-- Left Column: Details -->
      <div class="lg:col-span-8 space-y-8">
        
        <!-- Summary Box -->
        <div class="bg-white rounded-3xl border border-gray-200 p-6 md:p-8 shadow-sm space-y-4">
          <h2 class="font-bitter font-bold text-xl text-gray-900">🏭 Présentation générale du fabricant</h2>
          <p class="text-gray-600 leading-relaxed text-sm md:text-base font-light">{brand.description}</p>
        </div>

        <!-- Technical specifications table -->
        <div class="bg-white rounded-3xl border border-gray-200 p-6 shadow-sm space-y-4">
          <h3 class="font-bitter font-bold text-lg text-gray-900 border-b border-gray-100 pb-2">📋 Caractéristiques du système phare</h3>
          <div class="grid sm:grid-cols-2 gap-4 text-xs font-space pt-2">
            <div class="bg-gray-50 p-3.5 rounded-xl border border-gray-150">
              <span class="text-gray-400 block uppercase">Système vedette</span>
              <strong class="text-secondary text-sm block mt-1">{brand.phareSystem}</strong>
            </div>
            <div class="bg-gray-50 p-3.5 rounded-xl border border-gray-150">
              <span class="text-gray-400 block uppercase">Prix moyen indicatif posé</span>
              <strong class="text-secondary text-sm block mt-1">{brand.priceRange}</strong>
            </div>
            <div class="bg-gray-50 p-3.5 rounded-xl border border-gray-150">
              <span class="text-gray-400 block uppercase">Certifications valides</span>
              <div class="flex flex-wrap gap-1.5 mt-1.5">
                {brand.certifications.map(c => (
                  <span class="bg-teal-50 text-teal-800 px-2 py-0.5 rounded text-[9px] font-bold border border-teal-200/50">{c}</span>
                ))}
              </div>
            </div>
            <div class="bg-gray-50 p-3.5 rounded-xl border border-gray-150">
              <span class="text-gray-400 block uppercase">Pays d'origine</span>
              <strong class="text-secondary text-sm block mt-1">{brand.origin}</strong>
            </div>
          </div>
        </div>

        <!-- Pros and Cons -->
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-green-50/50 border border-green-200/80 rounded-3xl p-6 shadow-sm space-y-3">
            <h4 class="font-bitter font-bold text-gray-900 text-sm flex items-center gap-1.5 text-green-800">
              <span>🟢</span> Points Forts
            </h4>
            <ul class="space-y-2.5 text-xs text-gray-700">
              {brand.pros.map(pro => (
                <li class="flex items-start gap-2">
                  <span class="text-green-600 font-bold mt-0.5">✓</span>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-red-50/50 border border-red-200/80 rounded-3xl p-6 shadow-sm space-y-3">
            <h4 class="font-bitter font-bold text-gray-900 text-sm flex items-center gap-1.5 text-red-800">
              <span>🔴</span> Points Faibles
            </h4>
            <ul class="space-y-2.5 text-xs text-gray-700">
              {brand.cons.map(con => (
                <li class="flex items-start gap-2">
                  <span class="text-red-500 font-bold mt-0.5">✗</span>
                  <span>{con}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- CSTB warning text -->
        <div class="bg-gray-50 border-l-4 border-secondary rounded-r-xl p-5">
          <h4 class="font-bitter font-bold text-gray-900 text-sm mb-1.5">⚖️ L'importance d'un système homologué</h4>
          <p class="text-xs text-gray-600 leading-relaxed font-light">
            En isolation extérieure, l'assemblage isolant + colle + trame + enduit doit faire l'objet d'un Document Technique d'Application (DTA) délivré par le CSTB. Poser un isolant d'une marque avec l'enduit d'une autre marque annule la validité des assurances décennales et le versement des primes ANAH. Exigez de votre façadier la pose d'un système complet et homogène <strong>{brand.name}</strong>.
          </p>
        </div>

      </div>

      <!-- Right Column: Quote and directory -->
      <div class="lg:col-span-4 space-y-6">
        <div class="sticky top-20 space-y-6">
          <QuoteWidget keyword={`Système ITE ${brand.name}`} />

          <!-- All brands link -->
          <div class="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm space-y-4">
            <h4 class="font-bitter font-bold text-gray-900 text-sm border-b border-gray-150 pb-2">🏭 Autres Marques</h4>
            <ul class="space-y-2">
              {brands.map(b => (
                <li>
                  <a 
                    href={`/systemes/${b.slug}`}
                    class={`text-xs transition-colors block py-0.5 ${b.slug === brand.slug ? 'text-secondary font-bold' : 'text-gray-600 hover:text-secondary'}`}
                  >
                    • {b.name} ({b.phareSystem})
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
