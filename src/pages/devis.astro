---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWidget from '../components/QuoteWidget.astro';
import { siteConfig } from '../../site.config';
import { blogArticles } from '../data/blog-articles';
import { techniques } from '../data/techniques';
import { brands } from '../data/brands';
---

<BaseLayout
  title={`Devis ${siteConfig.niche.nameShort} Gratuit — Comparez 3 Artisans RGE | ${siteConfig.name}`}
  description={`Demandez votre devis ${siteConfig.niche.name.toLowerCase()} gratuit. Comparez jusqu'à 3 propositions d'installateurs certifiés RGE. Sans engagement.`}
  canonical="/devis"
>
  <section class="gradient-hero text-white py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">
        Demandez vos 3 Devis {siteConfig.niche.nameShort} Gratuits
      </h1>
      <p class="text-gray-300 text-lg max-w-xl mx-auto">
        Remplissez le formulaire ci-dessous. Des installateurs certifiés de votre département vous contactent sous 48h.
      </p>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-10 -mt-4">
    <QuoteWidget keyword={siteConfig.niche.name} />

    <div class="mt-8 grid sm:grid-cols-3 gap-4 text-center">
      <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
        <span class="text-2xl mb-2 block">🛡️</span>
        <span class="font-semibold text-sm text-gray-900">100% Gratuit</span>
        <p class="text-xs text-gray-500 mt-1">Aucuns frais cachés</p>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
        <span class="text-2xl mb-2 block">⚡</span>
        <span class="font-semibold text-sm text-gray-900">Réponse sous 48h</span>
        <p class="text-xs text-gray-500 mt-1">Artisans réactifs</p>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
        <span class="text-2xl mb-2 block">📋</span>
        <span class="font-semibold text-sm text-gray-900">Sans engagement</span>
        <p class="text-xs text-gray-500 mt-1">Comparez librement</p>
      </div>
    </div>
  </section>

  <!-- Cross-linking contextuel -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16">
    <div class="bg-gray-50 rounded-2xl border border-gray-200 p-6 md:p-8 space-y-6">
      <h2 class="font-bitter font-bold text-lg text-gray-900">🕸️ Préparez votre projet d'isolation</h2>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="space-y-3">
          <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">📚 Guides à Lire</h3>
          <ul class="space-y-2">
            {blogArticles.slice(0, 3).map((g) => (
              <li>
                <a href={`/guides/${g.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5 leading-relaxed">
                  {g.emoji} {g.title}
                </a>
              </li>
            ))}
            <li><a href="/guides" class="text-xs text-secondary font-bold font-space hover:underline block pt-1">Tous les guides →</a></li>
          </ul>
        </div>

        <div class="space-y-3">
          <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">⚙️ Techniques de Pose</h3>
          <ul class="space-y-2">
            {techniques.map((t) => (
              <li>
                <a href={`/techniques/${t.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5">
                  {t.emoji} {t.shortName} — {t.priceRange}
                </a>
              </li>
            ))}
            <li><a href="/techniques" class="text-xs text-secondary font-bold font-space hover:underline block pt-1">Comparatif →</a></li>
          </ul>
        </div>

        <div class="space-y-3">
          <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">🏭 Fabricants</h3>
          <ul class="space-y-2">
            {brands.map((b) => (
              <li>
                <a href={`/systemes/${b.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5">
                  • {b.name}
                </a>
              </li>
            ))}
            <li><a href="/systemes" class="text-xs text-secondary font-bold font-space hover:underline block pt-1">Tous les systèmes →</a></li>
          </ul>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-200 text-center">
        <a href="/annuaire" class="text-sm text-secondary font-bold hover:underline">📍 Trouver un artisan près de chez vous →</a>
      </div>
    </div>
  </section>
</BaseLayout>
