---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import { getAllCities, getAllDepartments, getCitiesByDepartment } from '../../lib/cities';
import { blogArticles } from '../../data/blog-articles';
import { techniques } from '../../data/techniques';
import { brands } from '../../data/brands';

const departments = getAllDepartments();
---

<BaseLayout
  title={`Annuaire ${siteConfig.niche.nameShort} par Ville — Tous les Départements | ${siteConfig.name}`}
  description={`Trouvez un installateur de ${siteConfig.niche.name.toLowerCase()} dans votre ville. Annuaire complet par département avec devis gratuits.`}
  canonical="/annuaire"
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">
        📍 Annuaire {siteConfig.niche.nameShort} par Ville
      </h1>
      <p class="text-gray-300 text-lg">
        Trouvez un installateur certifié RGE dans votre département
      </p>
    </div>
  </section>

  <!-- Cross-linking intro -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white rounded-2xl border border-gray-200 p-5 space-y-3">
        <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">📚 Guides & Conseils</h3>
        <ul class="space-y-2">
          {blogArticles.slice(0, 3).map((g) => (
            <li>
              <a href={`/guides/${g.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5 leading-relaxed">
                {g.emoji} {g.title}
              </a>
            </li>
          ))}
          <li><a href="/guides" class="text-xs text-secondary font-bold font-space hover:underline block pt-1">Tous les guides →</a></li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 p-5 space-y-3">
        <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">⚙️ Techniques de Pose</h3>
        <ul class="space-y-2">
          {techniques.map((t) => (
            <li>
              <a href={`/techniques/${t.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5">
                {t.emoji} {t.shortName} — {t.priceRange}
              </a>
            </li>
          ))}
          <li><a href="/techniques" class="text-xs text-secondary font-bold font-space hover:underline block pt-1">Comparatif →</a></li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 p-5 space-y-3">
        <h3 class="font-bitter font-bold text-sm text-gray-900 border-b border-gray-200 pb-2">🏭 Fabricants Certifiés</h3>
        <ul class="space-y-2">
          {brands.map((b) => (
            <li>
              <a href={`/systemes/${b.slug}`} class="text-xs text-gray-600 hover:text-secondary transition-colors block py-0.5">
                • {b.name}
              </a>
            </li>
          ))}
          <li><a href="/systemes" class="text-xs text-secondary font-bold font-space hover:underline block pt-1">Tous les systèmes →</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {departments.map((dept) => {
      const deptCities = getCitiesByDepartment(dept.code);
      return (
        <div id={`dept-${dept.code}`} class="mb-10">
          <h2 class="text-xl font-bold text-gray-900 mb-1 flex items-center gap-2">
            <span class="bg-brand-100 text-brand-700 px-2 py-0.5 rounded text-sm font-mono">{dept.code}</span>
            <a href={`/departement/${dept.code.toLowerCase()}`} class="hover:text-brand-600 transition-colors">
              {dept.name}
            </a>
            <span class="text-gray-400 text-sm font-normal">({dept.region})</span>
          </h2>
          <div class="flex flex-wrap gap-2 mt-3">
            {deptCities.map((city) => (
              <a
                href={`/${city.slug}`}
                class="bg-white border border-gray-200 rounded-lg px-3 py-2 hover:border-brand-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 hover:text-brand-600"
              >
                {city.name} ({city.zip})
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </section>
</BaseLayout>
