---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import { blogArticles } from '../../data/blog-articles';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Guides ITE — ${siteConfig.name}`,
    "description": "Guides d'experts, simulations de prix au m² et comparatifs complets d'isolation thermique par l'extérieur (ITE). Découvrez comment financer vos travaux.",
    "url": `https://www.${siteConfig.domain}/guides`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://www.${siteConfig.domain}` },
      { "@type": "ListItem", "position": 2, "name": "Guides ITE" },
    ]
  }
];
---

<BaseLayout
  title={`Guides Isolation Extérieure (ITE) 2026 — Prix au m² & Aides | ${siteConfig.name}`}
  description="Consultez nos 10 guides d'experts complets sur l'isolation thermique par l'extérieur (ITE) : prix au m² par technique, barèmes MaPrimeRénov' 2026, pièges de devis à éviter."
  canonical="/guides"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4">
      <span class="inline-flex bg-white/10 px-3.5 py-1.5 rounded-full text-xs font-semibold tracking-wider font-space uppercase">
        📚 E-E-A-T Performance Énergétique
      </span>
      <h1 class="text-3xl md:text-5xl font-bitter font-extrabold text-white">
        Guides & Conseils de l'Isolation Extérieure (ITE)
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto font-light">
        Tout comprendre de l'ITE en 5 minutes : simulations de coûts au m², cumul des aides de l'État 2026, choix des isolants et déroulement du chantier.
      </p>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {blogArticles.map((article, i) => (
        <a href={`/guides/${article.slug}`}
          class="bg-white border border-gray-200 rounded-2xl overflow-hidden hover:border-secondary hover:shadow-lg transition-all group flex flex-col justify-between"
        >
          <div>
            <div class="aspect-[16/10] bg-slate-800 flex items-center justify-center text-slate-500 text-xs font-space font-bold border-b border-gray-200 relative">
              <span class="absolute top-3 left-3 bg-white text-base w-8 h-8 rounded-full flex items-center justify-center shadow-md">{article.emoji}</span>
              [Image: {article.title.split(' ')[0]} {article.title.split(' ')[1]}]
            </div>
            
            <div class="p-6 space-y-3">
              <div class="flex items-center gap-2">
                <span class="text-[10px] font-bold text-teal-700 bg-teal-50 px-2 py-0.5 rounded-full font-space uppercase tracking-wider">{article.category}</span>
                <span class="text-[10px] text-gray-400 font-space">{article.readTime} de lecture</span>
              </div>

              <h2 class="font-bitter font-bold text-gray-900 group-hover:text-secondary transition-colors text-base leading-snug">
                {article.title}
              </h2>

              <p class="text-gray-600 text-xs leading-relaxed line-clamp-3">
                {article.excerpt}
              </p>
            </div>
          </div>

          <div class="p-6 pt-0 mt-auto flex items-center justify-between text-[11px] text-gray-400 font-space border-t border-gray-50 pt-4">
            <span>{article.date}</span>
            <span class="text-secondary font-bold group-hover:translate-x-1 transition-transform inline-block">
              Lire la suite →
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-slate-900 rounded-3xl p-8 md:p-12 text-center text-white space-y-4">
      <h2 class="text-2xl md:text-3xl font-bitter font-bold text-teal-400">
        Prêt à évaluer le coût réel pour votre façade ?
      </h2>
      <p class="text-slate-300 max-w-lg mx-auto text-sm">
        Comparez les prix de 3 poseurs certifiés RGE locaux. C'est 100% gratuit, rapide et sans engagement.
      </p>
      <a href="/devis" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-8 py-3.5 rounded-xl transition-all shadow-lg text-base transform hover:scale-[1.02]">
        🏠 Demander mes Devis Gratuits
      </a>
    </div>
  </section>
</BaseLayout>
